// EduFund Portal — Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum InstitutionType {
  UNIVERSITY
  COLLEGE
  HIGH_SCHOOL
  TVET
  PRIMARY_SCHOOL
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String
  password     String
  role         Role     @default(STUDENT)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications  Application[]
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AdminLogs")

  @@map("users")
}

model Application {
  id          String            @id @default(cuid())
  userId      String
  status      ApplicationStatus @default(DRAFT)
  referenceNo String            @unique @default(cuid())

  // Step 1: Personal Details
  fullName        String
  idNumber        String
  dateOfBirth     DateTime
  gender          Gender
  phone           String
  email           String
  county          String
  constituency    String?
  hasDisability   Boolean  @default(false)
  disabilityNotes String?

  // Step 2: Family Background
  guardianName      String
  guardianOccupation String
  householdIncome   Float
  dependents        Int
  isOrphan          Boolean @default(false)
  orphanStatus      String?

  // Step 3: Institution Details
  institutionType   InstitutionType
  institutionName   String
  institutionId     String?
  admissionNumber   String
  course            String
  yearOfStudy       Int
  totalFees         Float?

  // Step 4: Financial Need
  feesRequired      Float
  amountRequested   Float
  otherFunding      Float    @default(0)
  otherFundingSource String?
  personalStatement String

  // Step 5: Admin fields
  adminComment String?
  reviewedBy   String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  disbursedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  documents Document[]
  payment   Payment?
  statusLogs StatusLog[]

  @@map("applications")
}

model Document {
  id            String   @id @default(cuid())
  applicationId String
  fileName      String
  fileType      String
  fileSize      Int
  filePath      String
  documentType  String   // admission_letter, fee_structure, national_id, supporting
  uploadedAt    DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Payment {
  id              String        @id @default(cuid())
  applicationId   String        @unique
  userId          String
  amount          Float
  phone           String
  merchantRequestId String?
  checkoutRequestId String?
  mpesaReceiptNo  String?
  transactionDate DateTime?
  status          PaymentStatus @default(PENDING)
  resultCode      String?
  resultDesc      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  @@map("payments")
}

model StatusLog {
  id            String            @id @default(cuid())
  applicationId String
  status        ApplicationStatus
  changedBy     String
  comment       String?
  createdAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("status_logs")
}

model Institution {
  id          String          @id @default(cuid())
  name        String
  type        InstitutionType
  county      String
  code        String?
  website     String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("institutions")
}

model Bursary {
  id          String   @id @default(cuid())
  title       String
  description String
  amount      Float
  deadline    DateTime
  isOpen      Boolean  @default(true)
  eligibility String?
  provider    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bursaries")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  admin User @relation("AdminLogs", fields: [adminId], references: [id])

  @@map("audit_logs")
}
